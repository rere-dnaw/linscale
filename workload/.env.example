# ========== Workload Identity ==========
WORKLOAD_NAME=myapp
WORKLOAD_NS=workloads
WORKLOAD_IMAGE=nginx:latest

# ========== Instance Selection ==========
WORKLOAD_INSTANCE_TYPE=

# ========== Resources ==========
REPLICAS=1
CPU_REQUEST=500m
MEMORY_REQUEST=512Mi
CPU_LIMIT=2000m
MEMORY_LIMIT=2Gi

# ========== Web UI (via Traefik IngressRoute) ==========
WEB_HOST=app.example.com
WEB_PORT=8080
ENABLE_TLS=true

# ========== Extra Ports (NodePort only, bypass Traefik) ==========
# Format: NAME:PORT:PROTOCOL (comma-separated, no spaces)
# Example: sip:5060:TCP,stun:3478:UDP,rtp:19302:UDP
EXTRA_PORTS=x

# ========== Certificate ==========
CERT_ENABLED=true
CERT_EMAIL=admin@example.com

# ========== Storage ==========
PVC_ENABLED=true
PVC_SIZE=100Gi
PVC_STORAGE_CLASS=linode-block-storage-retain
PVC_ACCESS_MODE=ReadWriteOnce

# ========== Scale-to-Zero ==========
IDLE_TIMEOUT=30
IDLE_CHECK_INTERVAL=60

# ========== Cleanup ==========
PRESERVE_PVC_ON_DESTROY=true