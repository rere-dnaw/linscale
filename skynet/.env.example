# ========== Workload Identity ==========
WORKLOAD_NAME=skynet
WORKLOAD_NS=skynet
WORKLOAD_IMAGE=docker.io/yourorg/skynet:latest

# ========== GPU Instance ==========
WORKLOAD_INSTANCE_TYPE=g2-gpu-rtx4000a1-s

# ========== Resources ==========
REPLICAS=1
CPU_REQUEST=2
MEMORY_REQUEST=8Gi
CPU_LIMIT=4
MEMORY_LIMIT=16Gi

# ========== Web UI ==========
WEB_HOST=skynet.example.com
WEB_PORT=8000
ENABLE_TLS=true

# ========== Authorization (PROD) ==========
# Set BYPASS_AUTHORIZATION=false for production with proper JWT auth
BYPASS_AUTHORIZATION=false
ASAP_PUB_KEYS_REPO_URL=https://keys.example.com
ASAP_PUB_KEYS_FOLDER=/pub-keys
ASAP_PUB_KEYS_AUDS=skynet-api

# ========== Modules ==========
# Enable all modules: summaries (LLM), streaming_whisper (STT), assistant (RAG)
ENABLED_MODULES=summaries:dispatcher,summaries:executor,streaming_whisper,assistant,customer_configs

# ========== Models (Mounted via PVC at /models) ==========
# Whisper model path - should contain faster-whisper model files
WHISPER_MODEL_PATH=/models/streaming_whisper
# Whisper model name - set to auto-download (e.g., tiny.en, base.en, small.en)
# If WHISPER_MODEL_PATH is set and models exist, this is not needed
# WHISPER_MODEL_NAME=tiny.en

# LLM model path for vLLM inference
LLAMA_PATH=/models/llama-3.1-8b-instruct
LLAMA_N_CTX=80000

# Embeddings model for RAG
EMBEDDINGS_MODEL_PATH=BAAI/bge-m3

# ========== Whisper (GPU) ==========
WHISPER_COMPUTE_TYPE=int8
WHISPER_GPU_INDICES=0
BEAM_SIZE=5

# ========== Redis (Sidecar) ==========
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== Storage ==========
PVC_ENABLED=true
PVC_SIZE=100Gi
PVC_STORAGE_CLASS=linode-block-storage-retain
PVC_ACCESS_MODE=ReadWriteOnce

# ========== Certificate ==========
CERT_ENABLED=true
CERT_EMAIL=admin@example.com
